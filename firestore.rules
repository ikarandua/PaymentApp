rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidAmount() {
      return request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 10000;
    }
    
    function isValidTransaction() {
      let data = request.resource.data;
      return data.senderId is string
        && data.receiverId is string
        && data.amount is number
        && data.status is string;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (for looking up recipients)
      allow read: if isAuthenticated();
      
      // Users can only write to their own document
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        // Prevent direct balance modifications (should use transactions)
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance']);
      allow delete: if false;
      
      // Prevent negative balances
      match /balance/{balanceId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // Transactions collection
    match /transactions/{transactionId} {
      // Users can read transactions they're involved in
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
      
      // Transactions are created through Cloud Functions for security
      // This allows the app to create them during development
      allow create: if isAuthenticated() && 
        isValidTransaction() &&
        isValidAmount() &&
        request.resource.data.senderId == request.auth.uid;
      
      allow update, delete: if false;
    }

    // Payment requests collection
    match /paymentRequests/{requestId} {
      // Users can read requests they're involved in
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.fromId || 
         request.auth.uid == resource.data.toId);
      
      // Users can create payment requests
      allow create: if isAuthenticated() && 
        request.resource.data.fromId == request.auth.uid &&
        isValidAmount();
      
      // Users can update (accept/reject) requests they're the recipient of
      allow update: if isAuthenticated() && 
        request.auth.uid == resource.data.toId &&
        request.resource.data.status in ['accepted', 'rejected'];
      
      allow delete: if false;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
